{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/session-start.sh",
            "statusMessage": "graphy: checking knowledge graph"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/rebuild-async.sh"
          }
        ]
      }
    ]
  }
}
